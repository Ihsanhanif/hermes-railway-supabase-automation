{
  "build": {
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "healthCheck": {
      "path": "/",
      "timeout": 100,
      "interval": 30,
      "method": "GET"
    },
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "cronJobs": [
    {
      "name": "llm-monitor",
      "schedule": "*/5 * * * *",
      "command": "python3 /app/automations/llm_monitor.py"
    },
    {
      "name": "motivational-quote",
      "schedule": "0 0 * * *",
      "command": "python3 /app/automations/motivational_quote.py"
    },
    {
      "name": "market-brief",
      "schedule": "0 1 * * *",
      "command": "python3 /app/automations/market_brief.py"
    }
  ]
}